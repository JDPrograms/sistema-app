# Base de datos PostgreSQL (Neon)
# Obtener en: https://console.neon.tech → tu proyecto → Connection Details
# Usar "Connection string" con pooling activado
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# URL directa (sin pooling) - necesaria para migraciones de Prisma
# En Neon: misma seccion, pero desactivar "Pooler"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Secreto para las sesiones - genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-una-clave-secreta-aleatoria-larga"

# URL del sitio (en Vercel se configura automaticamente)
# Para desarrollo local:
NEXTAUTH_URL="http://localhost:3000"
# Para produccion en Vercel, poner la URL que te asigno Vercel:
# NEXTAUTH_URL="https://tu-app.vercel.app"

# API Keys de Inteligencia Artificial (planes gratuitos)
# Google Gemini - obtener en: https://aistudio.google.com → Get API key
GEMINI_API_KEY="tu-api-key-de-gemini"

# Groq (Llama 3, Mixtral) - obtener en: https://console.groq.com → API Keys
GROQ_API_KEY="tu-api-key-de-groq"

# Email (Resend) - obtener en: https://resend.com → API Keys
# IMPORTANTE: El remitente debe ser de un dominio verificado en Resend
# Para pruebas sin dominio propio usar: onboarding@resend.dev (solo envía al correo de la cuenta Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
SYSTEM_EMAIL_FROM="notificaciones@tudominio.com"

# Email del Director de Operaciones (recibe alertas automáticas)
DIRECTOR_EMAIL="jedimanbl@gmail.com"
