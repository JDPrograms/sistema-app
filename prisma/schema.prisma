generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SuperAdmin {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  isMaster    Boolean  @default(false)
  permissions String   @default("{}")
  mfaEnabled  Boolean  @default(false)
  mfaSecret   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AiProvider {
  id        String   @id @default(cuid())
  name      String   @unique // "gemini" | "groq" | "openai" | "anthropic"
  label     String
  apiKey    String   @default("")
  model     String   @default("")
  isActive  Boolean  @default(false)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiAgent {
  id                String   @id @default(cuid())
  name              String
  description       String?
  systemPrompt      String
  preferredProvider String?  // "gemini" | "groq" | null (auto)
  agentType         String   @default("general") // "admin" | "public" | "general"
  isActive          Boolean  @default(true)
  isGlobal          Boolean  @default(false)
  siteId            String?
  site              Site?    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Site {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  template       String
  isActive       Boolean  @default(true)
  hasAdminPanel  Boolean  @default(true)
  modules        String   @default("{}")
  primaryColor   String   @default("#3b82f6")
  secondaryColor String   @default("#1e40af")
  logoUrl        String?
  description    String?
  phone          String?
  address        String?
  email          String?
  chatAgentId    String?
  adminAgentId   String?
  planType       String   @default("unlimited") // "unlimited" | "timed"
  expiresAt      DateTime?
  expiryReason   String?
  whatsapp              String?
  mapUrl                String?
  customDomain          String?  @unique
  whatsappPhoneNumberId String?
  whatsappDisplayPhone  String?
  whatsappWabaId        String?
  whatsappToken         String?
  whatsappVerifyToken   String?
  whatsappAppId         String?
  whatsappAppSecret     String?
  instagramUserId       String?
  instagramToken        String?
  instagramVerifyToken  String?
  emailFrom             String?
  emailApiKey           String?
  pwaEnabled            Boolean  @default(false)
  pwaShortName          String?
  twaPackageName        String?
  twaFingerprint        String?
  socialLinks    String   @default("{}")
  businessHours  String   @default("[]")
  seoTitle       String?
  seoDescription String?
  pageBlocks     String   @default("[]")
  layoutConfig   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  billingConfig  String   @default("{}")

  admins         SiteAdmin[]
  users          SiteUser[]
  pages          SitePage[]
  services       SiteService[]
  products       SiteProduct[]
  ads            SiteAd[]
  appointments   SiteAppointment[]
  staff          SiteStaff[]
  aiAgents       AiAgent[]
  invoices       SiteInvoice[]
  expenses       SiteExpense[]
  inventoryLogs  SiteInventoryLog[]
  chatSessions      SiteChatSession[]
  chatAgents        SiteChatAgent[]
  supportQueues     SupportQueue[]
  pushSubscriptions PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  adminId   String?
  createdAt DateTime @default(now())

  @@index([siteId])
}

model SiteAdmin {
  id                 String    @id @default(cuid())
  email              String
  password           String
  name               String
  siteId             String
  site               Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  isOwner            Boolean   @default(false)
  permissions        String    @default("{}")
  googleId           String?
  googleLoginToken   String?
  googleLoginExpires DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([email, siteId])
  @@index([googleLoginToken])
}

model SiteUser {
  id                 String    @id @default(cuid())
  email              String
  password           String
  name               String
  phone              String?
  siteId             String
  site               Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  emailVerified      Boolean   @default(false)
  verifyToken        String?
  provider           String    @default("email") // "email" | "google"
  googleId           String?
  googleLoginToken   String?
  googleLoginExpires DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([email, siteId])
  @@index([verifyToken])
  @@index([googleLoginToken])
}

model SitePage {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title     String
  slug      String
  content   String   @default("")
  isHome    Boolean  @default(false)
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, slug])
}

model SiteService {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float?
  duration    Int?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteProduct {
  id             String   @id @default(cuid())
  siteId         String
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  price          Float?
  comparePrice   Float?
  stock          Int?
  lowStockAlert  Int?
  sku            String?
  category       String?
  imageUrl       String?
  featured       Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SiteStaff {
  id           String            @id @default(cuid())
  siteId       String
  site         Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name         String
  email        String?
  phone        String?
  specialty    String?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  appointments SiteAppointment[]
}

model SiteAppointment {
  id          String     @id @default(cuid())
  siteId      String
  site        Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  clientName  String
  clientEmail String
  clientPhone String?
  serviceId   String?
  serviceName String?
  staffId     String?
  staffName   String?
  staff       SiteStaff? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  date        String
  time        String
  notes       String?
  status      String     @default("pending")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model SiteAd {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title       String
  description String?
  imageUrl    String?
  linkUrl     String?
  buttonText  String?
  type        String   @default("banner")
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteInvoice {
  id            String    @id @default(cuid())
  siteId        String
  site          Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  type          String    @default("invoice") // "invoice" | "quote"
  number        String
  clientName    String
  clientEmail   String?
  clientPhone   String?
  clientAddress String?
  status        String    @default("draft") // draft|sent|paid|cancelled|accepted|rejected
  items         String    @default("[]")
  subtotal      Float     @default(0)
  taxRate       Float     @default(0)
  discount      Float     @default(0)
  total         Float     @default(0)
  notes         String?
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([siteId])
}

model SiteExpense {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  description String
  amount      Float
  category    String?
  date        DateTime @default(now())
  receipt     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([siteId])
}

model SiteInventoryLog {
  id            String   @id @default(cuid())
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  productId     String
  productName   String
  type          String   // "in" | "out" | "adjustment"
  quantity      Int
  previousStock Int?
  newStock      Int?
  reason        String?
  createdAt     DateTime @default(now())

  @@index([siteId])
}

model SiteChatSession {
  id                String         @id @default(cuid())
  siteId            String
  site              Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  clientName        String?
  clientEmail       String?
  status            String         @default("bot") // bot|waiting|human|resolved
  assignedAdminId   String?
  assignedAdminName String?
  queueId           String?
  queueName         String?
  queue             SupportQueue?  @relation(fields: [queueId], references: [id], onDelete: SetNull)
  channel           String         @default("web")
  whatsappFrom      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  messages          SiteChatMessage[]

  @@index([siteId])
  @@index([status])
  @@index([queueId])
}

model SiteChatMessage {
  id        String          @id @default(cuid())
  sessionId String
  session   SiteChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String          // "user" | "bot" | "human" | "system"
  content   String
  adminId   String?
  adminName String?
  createdAt DateTime        @default(now())

  @@index([sessionId])
}

model SiteChatAgent {
  id          String         @id @default(cuid())
  siteId      String
  site        Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  adminId     String
  adminName   String
  adminEmail  String
  isAlwaysOn  Boolean        @default(false)
  isAvailable Boolean        @default(true)
  createdAt   DateTime       @default(now())
  queues      SupportQueue[]

  @@unique([siteId, adminId])
  @@index([siteId])
}

model SupportQueue {
  id          String          @id @default(cuid())
  siteId      String
  site        Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isDefault   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  agents      SiteChatAgent[]
  sessions    SiteChatSession[]

  @@index([siteId])
}
